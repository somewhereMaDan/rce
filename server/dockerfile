FROM node:20-slim

# Installing only the docker CLI binary, not the full daemon
RUN apt-get update && apt-get install -y curl \
    && curl -fsSL https://download.docker.com/linux/static/stable/x86_64/docker-27.0.3.tgz \
    | tar xz --strip=1 -C /usr/local/bin docker/docker \
    && apt-get purge -y curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY . .

ENV PORT=5000

EXPOSE 5000

CMD [ "npm", "run" , "dev" ]